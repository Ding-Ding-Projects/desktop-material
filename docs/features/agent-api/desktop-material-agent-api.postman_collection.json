    {
      "name": "MCP over HTTP",
      "description": "Sessionless MCP JSON-RPC. HTTP authentication and transport limits are shared with REST.",
      "item": [
        {
          "name": "Initialize",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 1,\n  \"method\": \"initialize\",\n  \"params\": {}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{agentBaseUrl}}/mcp",
            "description": "Negotiates the implemented MCP protocol version `2025-03-26`."
          }
        },
        {
          "name": "Ping",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 2,\n  \"method\": \"ping\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{agentBaseUrl}}/mcp",
            "description": "Checks the MCP handler without executing an app command."
          }
        },
        {
          "name": "List tools",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 3,\n  \"method\": \"tools/list\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{agentBaseUrl}}/mcp",
            "description": "Returns the 24 static tool schemas plus validated active `github_api_<name>` tools."
          }
        },
        {
          "name": "Call tool",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 4,\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"{{commandName}}\",\n    \"arguments\": {{commandArgs}}\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{agentBaseUrl}}/mcp",
            "description": "Calls one MCP tool. Replace `commandName` and ensure `commandArgs` expands to a JSON object."
          }
        },
        {
          "name": "Initialized notification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"notifications/initialized\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{agentBaseUrl}}/mcp",
            "description": "A JSON-RPC notification has no `id`; Desktop Material acknowledges accepted `notifications/*` messages with HTTP 202 and no response body."
          }
        }
      ]
    },
    {
      "name": "Remote access mode lifecycle",
      "description": "These routes are hosted by the same server. Status is public transport metadata. Pairing exists only in Paired LAN mode. Local mode remains the recommended default. The collection never stores a pairing code or returned device token.",
      "item": [
        {
          "name": "Get public remote status",
          "request": {
            "auth": {
              "type": "noauth"
            },
