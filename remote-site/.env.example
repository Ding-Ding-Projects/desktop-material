# Use :8080 for private HTTP development. For production, set a DNS name so
# Caddy can obtain HTTPS automatically, for example remote.example.com.
REMOTE_SITE_ADDRESS=:8080
REMOTE_HTTP_PORT=8080
REMOTE_ACME_PORT=80
REMOTE_HTTPS_PORT=443

# Private URL reachable from the gateway container. Never include a token,
# password, pairing code, or other credential in this URL.
DESKTOP_MATERIAL_AGENT_URL=http://host.docker.internal:51000
